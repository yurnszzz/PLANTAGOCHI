rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /plants/{plantToken} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();

      // ONBOARDING: sekali saja saat plant_name masih null
      allow update: if
        resource.data.plant_name == null &&
        request.resource.data.plant_name is string &&
        request.resource.data.plant_name.size() > 0 &&
        request.resource.data.plant_name.size() <= 20;

      // GAMEPLAY: watering + check-in + likes + accessories + coins
      allow update: if
        resource.data.plant_name != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['total_waters', 'streak', 'longest_streak', 'level',
                    'last_watered_at', 'unlocked_achievements',
                    'community_likes', 'coins', 'accessories',
                    'equipped_accessory', 'last_checkin', 'is_active']);

      match /watering_logs/{logId} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
