rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /plants/{plantToken} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
      allow update: if
        resource.data.plant_name == null &&
        request.resource.data.plant_name is string &&
        request.resource.data.plant_name.size() > 0 &&
        request.resource.data.plant_name.size() <= 20;
      allow update: if
        resource.data.plant_name != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['total_waters','streak','longest_streak','level',
                    'last_watered_at','unlocked_achievements']) &&
        (resource.data.last_watered_at == null ||
         request.time > resource.data.last_watered_at + duration.value(7,'d'));
      match /watering_logs/{logId} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }
  }
}